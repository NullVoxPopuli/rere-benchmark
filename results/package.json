{
  "name": "results",
  "version": "0.0.0",
  "private": true,
  "license": "GPL 3.0",
  "author": "NullVoxPopuli",
  "scripts": {
    "build": "vite build",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "format": "prettier . --write",
    "lint:prettier": "prettier . --check",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "ember-tsc --noEmit",
    "start": "vite",
    "test": "concurrently \"pnpm:lint\" \"pnpm:test:*\" --names \"lint,test:\" --prefixColors auto",
    "test:ember": "NODE_ENV=development vite build --mode development && testem ci --port 0"
  },
  "type": "module",
  "imports": {
    "#config": "./app/config/environment.ts",
    "#types": "./app/types.ts",
    "#utils": "./app/utils.ts",
    "#frameworks": "./app/frameworks.ts",
    "#routes/*": "./app/routes/*",
    "#components/*": "./app/components/*"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "dependencies": {
    "@glimmer/component": "^2.0.0",
    "@sgratzl/chartjs-chart-boxplot": "^4.4.5",
    "chart.js": "^4.5.1",
    "culori": "^4.0.2",
    "decorator-transforms": "^2.3.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-source": "6.12.0-beta.1",
    "ember-strict-application-resolver": "^0.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@babel/runtime": "^7.28.6",
    "@ember/app-tsconfig": "^2.0.0",
    "@ember/optional-features": "^3.0.0",
    "@embroider/core": "4.4.4",
    "@embroider/macros": "1.20.0",
    "@embroider/vite": "1.6.0",
    "@glint/ember-tsc": "^1.1.1",
    "@glint/template": "^1.7.4",
    "@glint/tsserver-plugin": "^2.1.0",
    "@rollup/plugin-babel": "^6.1.0",
    "@types/culori": "^4.0.1",
    "@types/qunit": "^2.19.13",
    "@types/rsvp": "^4.0.9",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^9.2.1",
    "ember-eslint": "^0.6.1",
    "ember-template-lint": "^7.9.3",
    "eslint": "^9.19.0",
    "prettier": "github:prettier/prettier",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "testem": "^3.17.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-full-reload": "^1.2.0",
    "vite-plugin-virtual": "^0.5.0"
  },
  "engines": {
    "node": "^22.19.0 || ^24.0.0"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "type": "app",
    "version": 2
  }
}

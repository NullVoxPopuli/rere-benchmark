{
  "name": "my-app",
  "version": "0.0.0",
  "private": true,
  "description": "Ember ten-k-items-one-time benchmark app",
  "repository": "",
  "license": "MIT",
  "author": "",
  "type": "module",
  "imports": {
    "#app/*": "./app/*",
    "#config": "./app/config.ts",
    "#components/*": "./app/components/*",
    "#services/*": "./app/services/*",
    "#utils/*": "./app/utils/*"
  },
  "exports": {
    "./*": "./app/*"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "start": "vite",
    "lint:eslint": "eslint . --cache",
    "lint:eslint:fix": "eslint . --fix",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "format": "prettier --write .",
    "lint:prettier": "prettier --check .",
    "lint:types": "ember-tsc --noEmit"
  },
  "dependencies": {
    "@embroider/macros": "1.20.5",
    "@embroider/router": "3.0.6",
    "@glimmer/component": "2.1.1",
    "common": "link:../../../common",
    "decorator-transforms": "2.4.0",
    "ember-source": "7.3.0-alpha.5",
    "ember-strict-application-resolver": "0.1.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/plugin-transform-runtime": "7.29.7",
    "@babel/plugin-transform-typescript": "7.29.7",
    "@babel/runtime": "7.29.7",
    "@ember/app-tsconfig": "2.0.0",
    "@embroider/core": "4.6.2",
    "@glint/ember-tsc": "1.8.12",
    "@glint/template": "1.7.8",
    "@glint/tsserver-plugin": "2.5.18",
    "@nullvoxpopuli/ember-vite": "1.1.0",
    "@nullvoxpopuli/eslint-configs": "5.5.0",
    "@rollup/plugin-babel": "7.1.0",
    "babel-plugin-ember-template-compilation": "4.0.0",
    "concurrently": "9.2.4",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "prettier-plugin-ember-template-tag": "2.1.7",
    "typescript": "6.0.3",
    "vite": "8.1.5"
  },
  "engines": {
    "node": ">= 24"
  },
  "ember": {
    "edition": "octane"
  }
}

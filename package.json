{
  "name": "rere-benchmark",
  "private": true,
  "type": "module",
  "license": "GPL 3",
  "scripts": {
    "prepare": "pnpm install:common; pnpm install:results",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "format": "prettier . --write",
    "lint:prettier": "prettier . --check",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "install:common": "cd common; pnpm install",
    "install:results": "cd results; pnpm install",
    "start": "cd ./results; pnpm start",
    "cli": "node --experimental-strip-types ./src/runner/cli.ts",
    "copy": "node --experimental-strip-types ./src/runner/copy.ts",
    "bench": "node --experimental-strip-types ./src/runner/index.ts"
  },
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": "^22.19.0 || ^24.0.0"
  },
  "devDependencies": {
    "@clack/prompts": "^1.0.1",
    "@nullvoxpopuli/eslint-configs": "^5.5.0",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^22.13.1",
    "byte-size": "^9.0.1",
    "concurrently": "^9.2.1",
    "cosmiconfig": "^9.0.0",
    "eslint": "^9.39.3",
    "execa": "^9.6.1",
    "globby": "^16.1.1",
    "killable": "^1.0.1",
    "prettier": "github:prettier/prettier",
    "puppeteer": "^24.37.5",
    "systeminformation": "^5.31.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "package-ui": "^0.1.0",
    "package-up": "^5.0.0"
  }
}
